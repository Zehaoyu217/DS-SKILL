{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ds-workspace state",
  "type": "object",
  "required": ["current_v", "phase", "mode", "seed", "data_sha256", "env_lock_hash",
               "holdout_locked_at", "holdout_reads", "active_hypotheses",
               "open_blockers", "events_history"],
  "properties": {
    "current_v": { "type": "integer", "minimum": 1 },
    "phase": { "enum": ["FRAME","DGP","AUDIT","DATA_PREP","EDA","FEATURE_MODEL","VALIDATE","FINDINGS","MERGE","SHIP","ABORTED"] },
    "mode": { "enum": ["competition", "daily"], "description": "Chosen at FRAME (question 1e). Controls gate strictness." },
    "tracker": { "enum": ["mlflow", "wandb", null], "default": null, "description": "External experiment tracker integration." },
    "tracker_config": {
      "type": "object",
      "properties": {
        "project": { "type": "string" },
        "experiment": { "type": "string" }
      }
    },
    "seed": { "type": "integer" },
    "data_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "env_lock_hash": { "type": "string" },
    "holdout_locked_at": { "type": "string", "format": "date-time" },
    "holdout_reads": { "type": "integer", "minimum": 0 },
    "active_hypotheses": { "type": "array", "items": { "type": "string" } },
    "open_blockers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from","severity","ref"],
        "properties": {
          "from": { "type": "string" },
          "severity": { "enum": ["CRITICAL","HIGH","MEDIUM","LOW"] },
          "ref": { "type": "string" }
        }
      }
    },
    "events_history": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["v","event","ref","at"],
        "properties": {
          "v": { "type": "integer" },
          "event": { "enum": ["leakage-found","assumption-disproven","metric-plateau","cv-holdout-drift","covariate-shift","suspicious-lift","submission-drift","eval-harness-tampered","novel-modeling-flag","novel-feature-flag","budget-exceeded","auto-pivot","auto-defeat","anti-goodhart-failure","override-activated","meta-audit-triggered","coverage-stale","council-quorum-failed"] },
          "ref": { "type": "string" },
          "at": { "type": "string", "format": "date-time" }
        }
      }
    },
    "user_guidance_file": {
      "type": "string",
      "default": "USER_GUIDANCE.md",
      "description": "Path to the user guidance anchor file, relative to ds-workspace/."
    },
    "active_overrides": {
      "type": "array",
      "items": { "type": "string" },
      "default": [],
      "description": "Active permanent-scope override ids (override-vN-NNN) for reference."
    },
    "verbosity": {
      "type": "string",
      "enum": ["quiet", "normal", "verbose"],
      "default": "normal",
      "description": "Decision narration verbosity. Set via 'verbosity <level>' command."
    },
    "autonomous": {
      "type": "boolean",
      "default": false,
      "description": "True when <project-root>/autonomous.yaml is present and the loop is running unattended (Iron Law #22/#24 autonomous substitutions in effect)."
    },
    "last_meta_audit_v": {
      "type": ["integer", "null"],
      "default": null,
      "description": "Version at which the most recent Meta-Auditor run produced a verdict. Used to gate the N-version cadence declared in autonomous.yaml."
    },
    "plateau_streak": {
      "type": "integer",
      "minimum": 0,
      "default": 0,
      "description": "Consecutive versions without stat-sig CV improvement. Drives auto-pivot (Iron Law #22) when it crosses plateau_threshold."
    },
    "pattern_area_plateaus": {
      "type": "object",
      "description": "Per-pattern-area plateau counters; area ids match coverage.json.pattern_areas[].id. Used by auto-defeat (exhaustion_threshold across all areas).",
      "additionalProperties": { "type": "integer", "minimum": 0 }
    }
  },
  "additionalProperties": false
}
