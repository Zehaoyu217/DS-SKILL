{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ds-workspace leaderboard",
  "type": "object",
  "required": ["project","primary_metric","current_state","runs","disproven","events"],
  "properties": {
    "project": { "type": "string" },
    "primary_metric": {
      "type": "object",
      "required": ["name","direction"],
      "properties": {
        "name": { "type": "string" },
        "direction": { "enum": ["max","min"] }
      }
    },
    "current_state": {
      "type": "object",
      "required": ["v","phase","updated_at"],
      "properties": {
        "v": { "type": "integer" },
        "phase": { "type": "string" },
        "updated_at": { "type": "string", "format": "date-time" }
      }
    },
    "runs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id","v","created_at","model","params_summary","features_used",
                     "cv_mean","cv_std","cv_ci95","lift_vs_baseline","status",
                     "seed","data_sha256","env_lock_hash"],
        "properties": {
          "id": { "type": "string" },
          "v": { "type": "integer" },
          "created_at": { "type": "string", "format": "date-time" },
          "model": { "type": "string" },
          "params_summary": { "type": "string" },
          "features_used": { "type": "integer", "minimum": 0 },
          "feature_groups": { "type": "array", "items": { "type": "string" } },
          "cv_mean": { "type": "number" },
          "cv_std": { "type": "number", "minimum": 0 },
          "cv_ci95": {
            "type": "array", "minItems": 2, "maxItems": 2,
            "items": { "type": "number" }
          },
          "lift_vs_baseline": { "type": "number" },
          "feature_baseline": { "type": "boolean", "description": "true for the raw-feature reference run (Iron Law #19b)" },
          "default_params": { "type": "boolean", "description": "true for the library-default-params reference run before any tuning" },
          "tuning_run": { "type": "boolean", "description": "true for any hyperparameter-tuned run" },
          "feature_lift_vs_feature_baseline": { "type": ["number","null"], "description": "cv_mean delta over the feature_baseline run; null if no feature baseline exists yet" },
          "tuning_lift_vs_default": { "type": ["number","null"], "description": "cv_mean delta over the default_params run; null if no tuning was performed" },
          "status": { "enum": ["valid","superseded","invalidated"] },
          "invalidation_reason": { "type": ["string","null"] },
          "notes_ref": { "type": "string" },
          "baseline": { "type": "boolean" },
          "seed": { "type": "integer" },
          "data_sha256": { "type": "string" },
          "env_lock_hash": { "type": "string" },
          "secondary_metrics": {
            "type": "object",
            "description": "Values for every secondary metric declared in plans/v1.md.pre_registration.secondary_metrics (Iron Law #23). Keys match metric names; values are numeric measurements on this run. Required once secondary metrics are declared (v1 FRAME exit).",
            "additionalProperties": { "type": ["number", "null"] }
          },
          "budget_spent": {
            "type": "object",
            "description": "Resources consumed by this run against budget.json envelopes (Iron Law #21). Keys are envelope dimension names (compute_hours, wall_clock_days, api_cost_usd). Optional — orchestrator logs what it can measure.",
            "additionalProperties": { "type": ["number", "null"] }
          },
          "pattern_area": {
            "type": ["string", "null"],
            "description": "coverage.json.pattern_areas[].id this run addresses. Used by Iron Law #25 exhaustion accounting and auto-pivot pattern-selection."
          },
          "approach_id": {
            "type": ["string", "null"],
            "description": "coverage.json.pattern_areas[].approaches_tried[].id referenced by this run — ties the run to an explicit brainstormed approach."
          },
          "override_ids": {
            "type": "array",
            "items": { "type": "string" },
            "default": [],
            "description": "Override artifact ids (Iron Law #24) that authorized this run if any gate was relaxed (e.g., eval-harness-tampered override)."
          }
        }
      }
    },
    "disproven": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id","claim","lesson","date"],
        "properties": {
          "id": { "type": "string" },
          "claim": { "type": "string" },
          "lesson": { "type": "string" },
          "date": { "type": "string", "format": "date-time" }
        }
      }
    },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type","v","ref","at"],
        "properties": {
          "type": { "type": "string" },
          "v": { "type": "integer" },
          "ref": { "type": "string" },
          "at": { "type": "string", "format": "date-time" }
        }
      }
    }
  }
}
